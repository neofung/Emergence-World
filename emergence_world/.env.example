# Database
DATABASE_URL=sqlite+aiosqlite:///./emergence_world/backend/data/emergence.db

# LLM (Anthropic API)
LLM_BASE_URL=http://127.0.0.1:15721
LLM_API_KEY=your-api-key-here
LLM_DEFAULT_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096

# Simulation
TIME_MODE=accelerated
ACCELERATION_FACTOR=60
CONCURRENT_AGENTS=1

# Server
HOST=127.0.0.1
PORT=8000
